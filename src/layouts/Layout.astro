---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, T, getRoutes, type Locale } from '../data/site';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  locale = 'tr',
  ogImage = '/og/default.png',
  noIndex = false,
} = Astro.props;

const t = T[locale];
const r = getRoutes(locale);

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.domain).toString();
const ogImageURL = new URL(ogImage, Astro.site ?? SITE.domain).toString();

const pathSansLocale = Astro.url.pathname.replace(/^\/en/, '') || '/';
const altLocale = locale === 'tr' ? 'en' : 'tr';
const altURL = altLocale === 'en'
  ? new URL(`/en${pathSansLocale === '/' ? '' : pathSansLocale}`, Astro.site ?? SITE.domain).toString()
  : new URL(pathSansLocale, Astro.site ?? SITE.domain).toString();

const fullTitle = title.includes(SITE.brandName) ? title : `${title} · ${SITE.brandName}`;
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="tr" href={locale === 'tr' ? canonicalURL : altURL} />
  <link rel="alternate" hreflang="en" href={locale === 'en' ? canonicalURL : altURL} />
  <link rel="alternate" hreflang="x-default" href={locale === 'tr' ? canonicalURL : altURL} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content={locale === 'tr' ? 'tr_TR' : 'en_US'} />
  <meta property="og:locale:alternate" content={locale === 'tr' ? 'en_US' : 'tr_TR'} />
  <meta property="og:site_name" content={SITE.brandName} />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0E1E2B" />

  <link
    rel="preload"
    href="/fonts/InterVariable.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
  />
</head>
<body>
  <a href="#main" class="skip-link">{t.skipLink}</a>

  <Header locale={locale} currentPath={Astro.url.pathname} />

  <main id="main">
    <slot />
  </main>

  <Footer locale={locale} />
</body>
</html>
