---
/**
 * Lightbox overlay for gallery thumbnails.
 * Wires up to every `.gallery-masonry img` on the page: click a thumb to view it
 * centered, with prev/next, backdrop-click, close button, Escape and arrow keys.
 */
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
}

const { locale = 'tr' } = Astro.props;
const L =
  locale === 'en'
    ? { close: 'Close', prev: 'Previous', next: 'Next', dialog: 'Image viewer' }
    : { close: 'Kapat', prev: 'Önceki', next: 'Sonraki', dialog: 'Görsel görüntüleyici' };
---

<div class="lightbox" id="lightbox" hidden role="dialog" aria-modal="true" aria-label={L.dialog}>
  <button class="lightbox__close" type="button" aria-label={L.close}>&times;</button>
  <button class="lightbox__nav lightbox__nav--prev" type="button" aria-label={L.prev}>&lsaquo;</button>
  <img class="lightbox__img" src="" alt="" />
  <button class="lightbox__nav lightbox__nav--next" type="button" aria-label={L.next}>&rsaquo;</button>
</div>

<script>
  const lb = document.getElementById('lightbox');
  const thumbs = Array.from(
    document.querySelectorAll<HTMLImageElement>('.gallery-masonry img')
  );
  if (lb && thumbs.length) {
    const img = lb.querySelector<HTMLImageElement>('.lightbox__img')!;
    const closeBtn = lb.querySelector<HTMLButtonElement>('.lightbox__close')!;
    const prevBtn = lb.querySelector<HTMLButtonElement>('.lightbox__nav--prev')!;
    const nextBtn = lb.querySelector<HTMLButtonElement>('.lightbox__nav--next')!;
    let idx = -1;

    const show = (i: number) => {
      idx = (i + thumbs.length) % thumbs.length;
      const t = thumbs[idx];
      img.src = t.currentSrc || t.src;
      img.alt = t.alt;
    };
    const open = (i: number) => {
      show(i);
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lb.hidden = true;
      document.body.style.overflow = '';
    };

    thumbs.forEach((t, i) => {
      t.style.cursor = 'zoom-in';
      t.addEventListener('click', () => open(i));
    });
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(idx - 1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(idx + 1);
    });
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  }
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 15, 24, 0.92);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    padding: var(--s-4);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox__img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: var(--r-card);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
  }
  .lightbox__close,
  .lightbox__nav {
    position: absolute;
    border: none;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: background var(--t-fast);
  }
  .lightbox__close:hover,
  .lightbox__nav:hover,
  .lightbox__close:focus-visible,
  .lightbox__nav:focus-visible {
    background: var(--c-accent);
  }
  .lightbox__close {
    top: var(--s-4);
    right: var(--s-4);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    font-size: 2rem;
  }
  .lightbox__nav {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    font-size: 2.4rem;
    padding-bottom: 4px;
  }
  .lightbox__nav--prev {
    left: var(--s-4);
  }
  .lightbox__nav--next {
    right: var(--s-4);
  }
  @media (max-width: 600px) {
    .lightbox__nav {
      width: 42px;
      height: 42px;
      font-size: 2rem;
    }
  }
</style>
