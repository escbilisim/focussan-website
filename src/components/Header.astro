---
import { CONTACT, T, getRoutes, type Locale } from '../data/site';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = T[locale];
const r = getRoutes(locale);

const navItems = [
  { href: r.home, label: t.nav.home },
  { href: r.about, label: t.nav.about },
  { href: r.services, label: t.nav.services },
  { href: r.gallery, label: t.nav.gallery },
  { href: r.faq, label: t.nav.faq },
  { href: r.contact, label: t.nav.contact },
];

const langSwitchPath = locale === 'tr' ? '/en' : '/';
const langLabel = locale === 'tr' ? 'EN' : 'TR';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={r.home} class="site-header__brand" aria-label="Focussan">
      <img
        src="/logo.png"
        alt="Focussan"
        width="197"
        height="83"
        class="site-header__logo"
      />
    </a>

    <nav id="site-nav" class="site-header__nav" aria-label={locale === 'tr' ? 'Ana navigasyon' : 'Main navigation'}>
      <ul>
        {navItems.map(({ href, label }) => (
          <li>
            <a href={href} class:list={['site-header__nav-link', { 'is-active': currentPath === href }]}>{label}</a>
          </li>
        ))}
      </ul>
      <a href={CONTACT.whatsappHref} class="btn btn--primary site-header__nav-cta" target="_blank" rel="noopener">{t.cta.getQuote}</a>
    </nav>

    <div class="site-header__actions">
      <a href={langSwitchPath} class="site-header__lang" aria-label={`Switch language to ${langLabel}`}>
        {langLabel}
      </a>
      <a href={CONTACT.whatsappHref} class="btn btn--primary site-header__cta" target="_blank" rel="noopener">{t.cta.getQuote}</a>
      <button
        class="site-header__toggle"
        type="button"
        aria-label={locale === 'tr' ? 'Menüyü aç/kapat' : 'Toggle menu'}
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--c-cream);
    border-bottom: 1px solid var(--c-border);
    backdrop-filter: blur(8px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    height: var(--header-h);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-header__logo {
    height: 55px;
    width: auto;
    display: block;
  }

  @media (max-width: 600px) {
    .site-header__logo {
      height: 45px;
    }
  }

  /* Mobile: nav is a dropdown panel toggled by the hamburger (<900px) */
  .site-header__nav {
    display: none;
    position: absolute;
    top: var(--header-h);
    left: 0;
    right: 0;
    background: var(--c-cream);
    border-bottom: 1px solid var(--c-border);
    box-shadow: var(--sh-mid);
    padding: var(--s-3) var(--s-4) var(--s-4);
  }

  .site-header__nav.is-open {
    display: block;
  }

  .site-header__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .site-header__nav-link {
    display: block;
    color: var(--c-text);
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    padding: var(--s-3) 0;
    border-bottom: 1px solid var(--c-border);
    transition: color var(--t-fast), border-color var(--t-fast);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link.is-active {
    color: var(--c-accent-dark);
  }

  .site-header__nav-cta {
    display: block;
    text-align: center;
    margin-top: var(--s-4);
  }

  /* Hamburger toggle button (mobile only) */
  .site-header__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0 9px;
    background: none;
    border: 1px solid var(--c-border-strong);
    border-radius: var(--r-btn);
    cursor: pointer;
  }

  .site-header__toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-primary);
    border-radius: 2px;
    transition: transform var(--t-fast), opacity var(--t-fast);
  }

  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .site-header__toggle[aria-expanded='true'] .site-header__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--s-2);
  }

  .site-header__lang {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--c-text-muted);
    text-decoration: none;
    padding: var(--s-2) var(--s-3);
    border: 1px solid var(--c-border-strong);
    border-radius: var(--r-btn);
    transition: color var(--t-fast), border-color var(--t-fast);
  }

  .site-header__lang:hover {
    color: var(--c-primary);
    border-color: var(--c-primary);
  }

  .site-header__cta {
    padding: 0.5rem 1.1rem;
    font-size: 0.9rem;
  }

  @media (min-width: 900px) {
    .site-header__toggle {
      display: none;
    }
    .site-header__nav,
    .site-header__nav.is-open {
      display: block;
      position: static;
      background: none;
      border: none;
      box-shadow: none;
      padding: 0;
    }
    .site-header__nav ul {
      flex-direction: row;
      gap: var(--s-4);
    }
    .site-header__nav-link {
      display: inline;
      font-size: 0.95rem;
      padding: var(--s-2) 0;
      border-bottom: 2px solid transparent;
    }
    .site-header__nav-link:hover,
    .site-header__nav-link.is-active {
      border-bottom-color: var(--c-accent);
    }
    .site-header__nav-cta {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .site-header__cta {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-header__toggle');
  const nav = document.getElementById('site-nav');
  if (toggle && nav) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      nav.classList.toggle('is-open', open);
    };
    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    nav.querySelectorAll('a').forEach((link) =>
      link.addEventListener('click', () => setOpen(false))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>
