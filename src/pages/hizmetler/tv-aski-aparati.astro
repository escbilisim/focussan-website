---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';

const productGroupSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProductGroup',
  name: 'Focussan TV Askı Aparatları',
  description:
    'Galvaniz çelik gövde, matt siyah elektrostatik toz boya, evrensel VESA standardı uyumlu TV askı aparatları. 4 ürün ailesi: gövde tipi, 6 kollu hareketli, kelebek hareketli, tavan askı.',
  brand: { '@type': 'Brand', name: 'Focussan' },
  productGroupID: 'focussan-tv-mounts',
  hasVariant: [
    { '@type': 'Product', name: 'Gövde Tipi 35 cm' },
    { '@type': 'Product', name: 'Gövde Tipi 70 cm' },
    { '@type': 'Product', name: 'Gövde Tipi 85 cm' },
    { '@type': 'Product', name: 'Gövde Tipi 100 cm' },
    { '@type': 'Product', name: '6 Kollu Hareketli' },
    { '@type': 'Product', name: 'Kelebek Hareketli' },
    { '@type': 'Product', name: 'Tavan Askı' },
  ],
};

const families = [
  {
    id: 'govde-tipi',
    name: 'Gövde Tipi (Sabit)',
    tag: '4 model · 35-100 cm',
    desc: 'Duvara sabitlenen, hareketsiz askı sistemi. Dar gövde modelleri TV\'yi duvara yakın konumlandırır, geniş gövde modelleri büyük ekranlar için denge ve geniş açılı görüş sağlar.',
    models: [
      { name: 'Dar gövde 35 cm', tv: '24-43"' },
      { name: 'Dar gövde 70 cm', tv: '43-55"' },
      { name: 'Geniş gövde 85 cm', tv: '55-65"' },
      { name: 'Geniş gövde 100 cm', tv: '65-85"' },
    ],
    use: 'Ev salonu, ofis, otel odası',
  },
  {
    id: 'alti-kollu',
    name: '6 Kollu Hareketli',
    tag: 'Çok eksenli',
    desc: '6 mafsallı kol sayesinde ileri-geri uzatma, sağ-sol döndürme ve eğim (tilt) hareketleri. Profesyonel kurulum için tasarlandı.',
    models: [
      { name: 'Tek model', tv: '50-85"' },
    ],
    use: 'Ev sineması, toplantı odası, otel lobisi, yayın stüdyosu, kontrol odası',
  },
  {
    id: 'kelebek',
    name: 'Kelebek Hareketli',
    tag: 'Çift kollu kelebek',
    desc: 'Çift kollu kelebek mekanizması. Kapalıyken duvar çıkıntısı minimum, açıkken geniş projeksiyon ve çok yönlü hareket. Ağır TV destekli.',
    models: [
      { name: 'Tek model', tv: '40-75"' },
    ],
    use: 'Yatak odası, küçük salon, esnek kullanım gerektiren mekanlar',
  },
  {
    id: 'tavan',
    name: 'Tavan Askı',
    tag: '360° döndürme',
    desc: 'Tavana monte edilen askı; ayarlanabilir kol uzunluğu farklı tavan yüksekliklerine uyum sağlar. 360° döndürme ile tüm yönlere bakış.',
    models: [
      { name: 'Tek model, ayarlanabilir', tv: '32-65"' },
    ],
    use: 'Mağaza, restoran, eğitim tesisi, fuar, havalimanı, hastane',
  },
];
---

<Layout
  title="VESA TV Askı Aparatı Üreticisi · Galvaniz Çelik · Focussan"
  description="Galvaniz çelik gövde + matt siyah elektrostatik toz boya, evrensel VESA standardı uyumlu TV askı aparatları. 4 ürün ailesi: gövde tipi (35-100 cm), 6 kollu hareketli, kelebek, tavan askı."
  locale="tr"
  ogImage="/og/tv-aski-aparati.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(productGroupSchema)} />

  <section class="hero section">
    <div class="container container--narrow">
      <p class="hero__eyebrow">ÜRÜN</p>
      <h1>VESA Standardı TV Askı Aparatları</h1>
      <p class="lead">
        Galvaniz çelik gövde, matt siyah elektrostatik toz boya. Tüm modeller evrensel VESA plakası ile birden fazla TV markası ve boyutuyla uyumlu. Kablo yönetim kanalı standart.
      </p>
    </div>
  </section>

  <section class="section tldr">
    <div class="container container--narrow">
      <div class="tldr__box">
        <p class="tldr__label">Özetle</p>
        <p>
          Focussan, galvaniz çelik üzerine matt siyah elektrostatik toz boya uygulanmış <strong>4 farklı TV askı aparatı ailesi</strong> üretir: sabit <strong>gövde tipi</strong> (35, 70, 85, 100 cm), <strong>6 kollu hareketli</strong>, <strong>kelebek hareketli</strong> ve <strong>tavan askı</strong>. Tüm modeller VESA 75×75 ile 600×400 arası evrensel plakaya sahiptir, çoğu marka ve 24-100 inç arası ekran ile uyumludur.
        </p>
      </div>
    </div>
  </section>

  <section class="section families">
    <div class="container">
      <h2>Ürün Aileleri</h2>
      <div class="families__grid">
        {families.map((f) => (
          <article class="family" id={f.id}>
            <p class="family__tag">{f.tag}</p>
            <h3>{f.name}</h3>
            <p class="family__desc">{f.desc}</p>
            <ul class="family__models">
              {f.models.map((m) => (
                <li><strong>{m.name}</strong><span>{m.tv}</span></li>
              ))}
            </ul>
            <p class="family__use"><strong>Kullanım alanı:</strong> {f.use}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section product-video">
    <div class="container container--narrow">
      <div class="product-video__head">
        <p class="product-video__eyebrow">ÜRÜN VİDEOSU</p>
        <h2>TV askı aparatımızı yakından görün</h2>
      </div>

      <div class="product-video__frame">
        <video
          id="tv-mount-video"
          controls
          preload="none"
          poster="/videos/focussan-tv-aski-poster.jpg"
          playsinline
        >
          <source src="/videos/focussan-tv-aski.webm" type="video/webm" />
          <source src="/videos/focussan-tv-aski.mp4" type="video/mp4" />
          Tarayıcınız HTML5 videoyu desteklemiyor.
        </video>
        <button class="product-video__play" type="button" aria-label="Ürün videosunu oynat">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <section class="section section--cream specs">
    <div class="container">
      <h2>Ortak Teknik Özellikler</h2>
      <div class="specs__grid">
        <div><strong>Gövde malzemesi</strong><span>Galvaniz çelik (paslanma direnci yüksek)</span></div>
        <div><strong>Yüzey kaplama</strong><span>Matt siyah elektrostatik toz boya · kendi tesisimizde</span></div>
        <div><strong>VESA uyumu</strong><span>75×75 ile 600×400 arası evrensel plaka</span></div>
        <div><strong>Marka uyumu</strong><span>Samsung, LG, Sony, Vestel, Arçelik, Beko ve VESA standartına uyan tüm markalar</span></div>
        <div><strong>Kablo yönetimi</strong><span>Standart kanal sistemi ile temiz görünüm</span></div>
        <div><strong>Montaj kiti</strong><span>Vidalar ve montaj talimatı kutu içinde</span></div>
      </div>
    </div>
  </section>

  <section class="section vesa">
    <div class="container container--narrow">
      <h2>VESA Standardı Nedir?</h2>
      <p>
        VESA (Video Electronics Standards Association) Mounting Interface Standard, TV arkasındaki montaj deliği aralığını standartlaştıran ölçüdür. Doğru askıyı seçmek için TV'nin destekledİği VESA değerini bilmek yeterlidir.
      </p>
      <table class="vesa__table">
        <thead>
          <tr><th>VESA Değeri</th><th>Tipik Ekran</th></tr>
        </thead>
        <tbody>
          <tr><td>75×75 / 100×100</td><td>15-32 inç</td></tr>
          <tr><td>200×200</td><td>32-37 inç</td></tr>
          <tr><td>200×100 / 300×300</td><td>37-50 inç</td></tr>
          <tr><td>400×400</td><td>50-65 inç</td></tr>
          <tr><td>600×400</td><td>65-75 inç</td></tr>
          <tr><td>800×400</td><td>75 inç ve üstü</td></tr>
        </tbody>
      </table>
      <p class="muted">Focussan aparatlarımız 75×75 ile 600×400 arasındaki tüm VESA değerlerini tek plakada destekler.</p>
    </div>
  </section>

  <section class="section section--cream b2b">
    <div class="container container--narrow text-center">
      <h2>Toptan ve Proje Talepleri</h2>
      <p class="lead">AV entegratörü, otel zinciri, perakende grubu, mağaza ağı veya distribütör iseniz proje bazlı fiyatlandırma ile çalışıyoruz.</p>
    </div>
  </section>

  <section class="section faq">
    <div class="container container--narrow">
      <h2>Sıkça Sorulan Sorular</h2>
      <details>
        <summary>Hangi TV markaları ile uyumlu?</summary>
        <p>VESA standartına uyan tüm markalar: Samsung, LG, Sony, Vestel, Arçelik, Beko, Philips, Panasonic, Hisense, TCL ve diğerleri. Marka değil, TV'nin VESA değeri belirleyicidir.</p>
      </details>
      <details>
        <summary>TV'min VESA değerini nasıl öğrenirim?</summary>
        <p>TV'nin kullanım kılavuzu veya arka kapak etiketinde belirtilir. Üretici web sitesinde model adıyla aranınca da görülür. Genellikle "VESA 200×200 mm" şeklinde yazılır.</p>
      </details>
      <details>
        <summary>Kurulum kiti dahil mi?</summary>
        <p>Evet. Tüm aparatlar vidalar ve montaj talimatı ile birlikte gönderilir. Standart bir matkap ve seviye ile evde monte edilebilir.</p>
      </details>
      <details>
        <summary>Toptan veya proje teklifi için minimum sipariş var mı?</summary>
        <p>Proje bazlı çalışıyoruz; minimum adet projeye göre değişiyor. Tip ve adet bilgisiyle iletişime geçtiğinizde teklif veriyoruz.</p>
      </details>
    </div>
  </section>

  <CTASection
    locale="tr"
    title="Toptan veya proje teklifi alın"
    description="Tip, adet ve teslimat noktası bilgisiyle iletişime geçin, projeye özel fiyatlandırma yapalım."
  />
</Layout>

<script>
  const video = document.getElementById('tv-mount-video') as HTMLVideoElement | null;
  const btn = document.querySelector<HTMLButtonElement>('.product-video__play');
  if (video && btn) {
    const hide = () => btn.setAttribute('hidden', '');
    const show = () => btn.removeAttribute('hidden');
    btn.addEventListener('click', () => {
      video.play();
      hide();
    });
    video.addEventListener('play', hide);
    video.addEventListener('ended', show);
  }
</script>

<style>
  .hero { padding-top: var(--s-7); padding-bottom: var(--s-5); }
  .hero__eyebrow {
    color: var(--c-accent-dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    margin: 0 0 var(--s-3);
  }

  .section--cream {
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }

  /* ===== Product video (vertical 9:16) ===== */
  .product-video {
    background: var(--c-primary-deep);
    color: var(--c-text-light);
  }
  .product-video__head {
    text-align: center;
    margin-bottom: var(--s-5);
  }
  .product-video__eyebrow {
    color: var(--c-accent-light);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    margin: 0 0 var(--s-2);
  }
  .product-video__head h2 {
    color: var(--c-white);
    margin: 0;
  }
  .product-video__frame {
    position: relative;
    width: 100%;
    max-width: 360px;
    margin: 0 auto;
    aspect-ratio: 9 / 16;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
  }
  .product-video__frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-video__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: rgba(255, 106, 0, 0.92);
    border: 4px solid rgba(255, 255, 255, 0.92);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    padding: 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    transition: background var(--t-fast), transform var(--t-fast);
  }
  .product-video__play:hover,
  .product-video__play:focus-visible {
    background: var(--c-accent);
    transform: translate(-50%, -50%) scale(1.06);
  }
  .product-video__play svg {
    width: 34px;
    height: 34px;
    fill: #fff;
    margin-left: 4px;
  }
  .product-video__play[hidden] {
    display: none;
  }

  .tldr { padding-top: 0; }
  .tldr__box {
    background: var(--c-white);
    border-left: 4px solid var(--c-accent);
    padding: var(--s-4);
    border-radius: var(--r-card);
    box-shadow: var(--sh-soft);
  }
  .tldr__label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--c-accent-dark);
    margin: 0 0 var(--s-2);
  }
  .tldr__box p { margin: 0; font-size: 1.05rem; line-height: 1.7; }

  .families__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
    margin-top: var(--s-4);
  }
  @media (min-width: 800px) {
    .families__grid { grid-template-columns: 1fr 1fr; }
  }

  .family {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    padding: var(--s-4);
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .family:hover {
    border-color: var(--c-accent);
    box-shadow: var(--sh-mid);
  }
  .family__tag {
    display: inline-block;
    background: var(--c-cream);
    color: var(--c-accent-dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 999px;
    margin: 0 0 var(--s-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .family h3 { margin: 0 0 var(--s-2); font-size: 1.25rem; }
  .family__desc { color: var(--c-text-muted); margin-bottom: var(--s-3); }
  .family__models { list-style: none; padding: 0; margin: 0 0 var(--s-3); }
  .family__models li {
    display: flex;
    justify-content: space-between;
    padding: var(--s-2) 0;
    border-top: 1px dashed var(--c-border);
    font-size: 0.95rem;
  }
  .family__models li:last-child { border-bottom: 1px dashed var(--c-border); }
  .family__models span { color: var(--c-text-muted); }
  .family__use { font-size: 0.9rem; color: var(--c-text-muted); margin: 0; }

  .specs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-4);
  }
  .specs__grid > div {
    background: var(--c-cream);
    padding: var(--s-3) var(--s-4);
    border-radius: var(--r-card);
    border-left: 3px solid var(--c-accent);
  }
  .specs__grid strong { display: block; color: var(--c-primary); margin-bottom: 4px; }
  .specs__grid span { color: var(--c-text-muted); font-size: 0.9rem; line-height: 1.5; }

  .vesa__table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--s-4) 0 var(--s-3);
    background: var(--c-white);
    border-radius: var(--r-card);
    overflow: hidden;
    box-shadow: var(--sh-soft);
  }
  .vesa__table th, .vesa__table td {
    padding: var(--s-2) var(--s-3);
    text-align: left;
    border-bottom: 1px solid var(--c-border);
  }
  .vesa__table thead {
    background: var(--c-primary);
    color: var(--c-white);
  }
  .vesa__table tbody tr:nth-child(even) { background: var(--c-cream); }

  .muted { color: var(--c-text-muted); font-size: 0.95rem; }

  .faq details {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    margin-bottom: var(--s-2);
  }
  .faq summary {
    padding: var(--s-3) var(--s-4);
    cursor: pointer;
    font-weight: 600;
    color: var(--c-primary);
    list-style: none;
    position: relative;
  }
  .faq summary::after {
    content: '+';
    position: absolute;
    right: var(--s-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--c-accent);
    font-size: 1.5rem;
    line-height: 1;
    transition: transform var(--t);
  }
  .faq details[open] summary::after { transform: translateY(-50%) rotate(45deg); }
  .faq details p { padding: 0 var(--s-4) var(--s-4); margin: 0; color: var(--c-text-muted); }
</style>
