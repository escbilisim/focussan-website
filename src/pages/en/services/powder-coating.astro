---
import Layout from '../../../layouts/Layout.astro';
import CTASection from '../../../components/CTASection.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Industrial Electrostatic Powder Coating',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Focussan Metal Sanayi Ticaret A.Ş.',
    url: 'https://focussan.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'DESB OSB Deliklikaya Mah. GünAlan Caddesi No: 23/1',
      addressLocality: 'Arnavutköy',
      addressRegion: 'İstanbul',
      addressCountry: 'TR',
    },
    telephone: '+90 212 873 07 34',
  },
  areaServed: { '@type': 'Country', name: 'Turkey' },
  description:
    'Industrial electrostatic powder coating up to 8 metres. Full RAL palette, matte/gloss/semi-matte/textured finishes, 2-5 business day average turnaround. Located at DESB OSB, Arnavutköy, Istanbul.',
};
---

<Layout
  title="Industrial Powder Coating Turkey · Up to 8 m · Focussan"
  description="Industrial electrostatic powder coating in Istanbul up to 8 metres. Full RAL palette, matte/gloss/semi-matte/textured finishes, 2-5 day average turnaround. Located at DESB OSB Arnavutköy."
  locale="en"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <section class="hero section">
    <div class="container container--narrow">
      <p class="hero__eyebrow">SERVICE</p>
      <h1>Industrial Electrostatic Powder Coating</h1>
      <p class="lead">
        Industrial electrostatic powder coating for parts up to 8 metres at DESB OSB Arnavutköy, Istanbul. Full RAL palette, matte / gloss / semi-matte / textured finishes, 2-5 business day average turnaround. We coat customer parts on contract and our own VESA TV bracket products on the same line.
      </p>
    </div>
  </section>

  <section class="section tldr">
    <div class="container container--narrow">
      <div class="tldr__box">
        <p class="tldr__label">At a glance</p>
        <p>
          <strong>Electrostatic powder coating</strong> applies negatively charged paint particles to a grounded metal surface, then cures the part at approximately 180-200 °C. The process is solvent-free and environmentally friendly. Compared to liquid paint, it offers 2-3× better scratch, impact and corrosion resistance. Focussan handles parts up to <strong>8 metres in length</strong>, supports the full RAL palette and four finish types, with an <strong>average 2-5 business day turnaround</strong>.
        </p>
      </div>
    </div>
  </section>

  <section class="section process">
    <div class="container">
      <h2>Process Steps</h2>
      <ol class="process__list">
        <li>
          <span class="process__num">01</span>
          <h3>Surface Preparation</h3>
          <p>Removal of grease, rust, and dirt through chemical pre-treatment baths or mechanical cleaning. Critical for paint adhesion.</p>
        </li>
        <li>
          <span class="process__num">02</span>
          <h3>Masking</h3>
          <p>Threaded holes, mounting surfaces and other no-paint zones protected with specialised tape or caps.</p>
        </li>
        <li>
          <span class="process__num">03</span>
          <h3>Electrostatic Spray</h3>
          <p>Negatively charged powder particles attracted to the grounded part. Uniform coverage on corners and recesses.</p>
        </li>
        <li>
          <span class="process__num">04</span>
          <h3>Curing</h3>
          <p>Polymerisation at 180-200 °C in the oven. Single-coat film thickness of 60-120 microns.</p>
        </li>
        <li>
          <span class="process__num">05</span>
          <h3>Cooling and QC</h3>
          <p>Visual inspection, film thickness measurement, adhesion testing. Ready for dispatch.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section section--cream capacity">
    <div class="container">
      <div class="capacity__grid">
        <div class="capacity__main">
          <p class="capacity__eyebrow">CAPACITY</p>
          <h2>Parts up to 8 Metres</h2>
          <p>
            Most subcontract powder coating shops cap out at 3-4 metres. Focussan's extended oven system handles industrial parts up to 8 metres, ideal for automotive profiles, structural steel, architectural extrusions, racking systems and large agricultural equipment components.
          </p>
        </div>
        <ul class="capacity__stats">
          <li><strong>8 m</strong><span>Maximum part length</span></li>
          <li><strong>60-120 µ</strong><span>Single-coat film thickness</span></li>
          <li><strong>180-200 °C</strong><span>Cure temperature</span></li>
          <li><strong>10+ yr</strong><span>UV-stable outdoor durability</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section materials">
    <div class="container">
      <div class="two-col">
        <div>
          <h2>Compatible Substrates</h2>
          <p>Powder coating only works on conductive surfaces:</p>
          <ul class="check-list">
            <li>Steel (hot-rolled / cold-rolled)</li>
            <li>Aluminium (extrusions, castings)</li>
            <li>Stainless steel</li>
            <li>Galvanised sheet</li>
            <li>Cast iron</li>
          </ul>
          <p class="muted">Non-conductive materials such as plastic, wood and MDF are not suitable.</p>
        </div>
        <div>
          <h2>Colour and Finish</h2>
          <p>Full <strong>RAL Classic</strong> palette (213 standard colours), <strong>RAL Design</strong> with 1,625 colours, NCS and custom matching on request.</p>
          <ul class="check-list">
            <li>Matte finish</li>
            <li>Gloss finish</li>
            <li>Semi-matte finish</li>
            <li>Textured finish</li>
            <li>Metallic / pearl (RAL Effect)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream sectors">
    <div class="container">
      <h2>Industries We Serve</h2>
      <div class="sectors__grid">
        <div><strong>Automotive sub-suppliers</strong><span>Chassis parts, wheels, suspension</span></div>
        <div><strong>Steel &amp; aluminium profiles</strong><span>Door / window framing, architectural</span></div>
        <div><strong>Racking systems</strong><span>Industrial storage, retail shelving</span></div>
        <div><strong>Electrical enclosures</strong><span>Field cabinets, distribution panels</span></div>
        <div><strong>Architectural metalwork</strong><span>Railings, stairs, façade elements</span></div>
        <div><strong>Agricultural machinery</strong><span>Tractor parts, equipment</span></div>
      </div>
    </div>
  </section>

  <section class="section pricing">
    <div class="container container--narrow">
      <h2>Transparent Pricing</h2>
      <p>We don't quote off a fixed price list. To give you a precise estimate we evaluate:</p>
      <ul class="numbered-list">
        <li><span>1.</span> <div><strong>Quantity</strong>: Larger volumes reduce per-m² cost.</div></li>
        <li><span>2.</span> <div><strong>Surface area (m²)</strong>: Total area to be coated.</div></li>
        <li><span>3.</span> <div><strong>Coating type</strong>: Epoxy, polyester, hybrid, polyurethane have different unit costs.</div></li>
        <li><span>4.</span> <div><strong>Number of colour changes</strong>: Single-colour runs are most economical.</div></li>
        <li><span>5.</span> <div><strong>Surface preparation difficulty</strong>: New metal is fast; rusted / dirty parts add bath time.</div></li>
        <li><span>6.</span> <div><strong>Size</strong>: 8 m parts require dedicated oven scheduling.</div></li>
      </ul>
      <p class="muted">For a precise quote send us a part drawing or sample photo.</p>
    </div>
  </section>

  <section class="section section--cream complementary">
    <div class="container container--narrow">
      <h2>Complementary Services</h2>
      <p>Adjacent services we offer alongside powder coating:</p>
      <ul class="check-list">
        <li><strong>Sheet &amp; steel supply</strong> · cold-rolled, hot-rolled, galvanised, pre-painted</li>
        <li><strong>Chemical pre-treatment</strong> · surface prep baths before powder coating</li>
        <li><strong>Masking service</strong> · protection of sensitive areas</li>
        <li><strong>Durability testing</strong> · salt spray, abrasion, adhesion on request</li>
        <li><strong>On-site support</strong> · technical installation assistance</li>
      </ul>
    </div>
  </section>

  <section class="section faq">
    <div class="container container--narrow">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>Which metals can be coated?</summary>
        <p>Steel, aluminium, stainless, galvanised and cast iron — all conductive metals. Plastics, wood, MDF are not suitable.</p>
      </details>
      <details>
        <summary>What is your maximum part length?</summary>
        <p>Up to 8 metres. Most subcontract shops cap at 3-4 m, so we can serve large industrial profiles and racking systems.</p>
      </details>
      <details>
        <summary>What's your turnaround time?</summary>
        <p>Standard work averages 2-5 business days. Time varies with quantity, colour changes and surface prep complexity; we confirm exact timing with the quote.</p>
      </details>
      <details>
        <summary>Suitable for outdoor use?</summary>
        <p>Yes — polyester or polyurethane powder gives 10+ years of UV-stable outdoor durability for architectural profiles, agricultural machinery and rooftop elements.</p>
      </details>
      <details>
        <summary>Is it environmentally friendly?</summary>
        <p>Yes. Powder coating is solvent-free with zero VOC emissions. Unused powder is 95%+ recoverable, producing significantly less waste than liquid paint.</p>
      </details>
    </div>
  </section>

  <CTASection
    locale="en"
    title="Get a precise quote for your parts"
    description="Send drawings, photos or technical specs — we typically respond within one business day."
  />
</Layout>

<style>
  .hero { padding-top: var(--s-7); padding-bottom: var(--s-5); }
  .hero__eyebrow {
    color: var(--c-accent-dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    margin: 0 0 var(--s-3);
  }
  .section--cream { background: var(--c-white); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border); }
  .tldr { padding-top: 0; }
  .tldr__box { background: var(--c-white); border-left: 4px solid var(--c-accent); padding: var(--s-4); border-radius: var(--r-card); box-shadow: var(--sh-soft); }
  .tldr__label { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; font-weight: 700; color: var(--c-accent-dark); margin: 0 0 var(--s-2); }
  .tldr__box p { margin: 0; font-size: 1.05rem; line-height: 1.7; }
  .process__list { list-style: none; padding: 0; margin: var(--s-4) 0 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--s-4); }
  .process__list li { background: var(--c-white); padding: var(--s-4); border-radius: var(--r-card); border: 1px solid var(--c-border); }
  .process__num { color: var(--c-accent-dark); font-weight: 800; font-size: 1.1rem; letter-spacing: 0.04em; }
  .process__list h3 { font-size: 1.1rem; margin: var(--s-2) 0 var(--s-2); }
  .process__list p { color: var(--c-text-muted); font-size: 0.95rem; margin: 0; }
  .capacity__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-5); align-items: center; }
  @media (min-width: 800px) { .capacity__grid { grid-template-columns: 1.4fr 1fr; } }
  .capacity__eyebrow { color: var(--c-accent-dark); font-weight: 700; font-size: 0.85rem; letter-spacing: 0.16em; margin: 0 0 var(--s-2); }
  .capacity__stats { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); }
  .capacity__stats li { background: var(--c-cream); padding: var(--s-3); border-radius: var(--r-card); text-align: center; border: 1px solid var(--c-border); }
  .capacity__stats strong { display: block; font-size: 1.4rem; color: var(--c-primary); font-weight: 800; }
  .capacity__stats span { font-size: 0.8rem; color: var(--c-text-muted); }
  .two-col { display: grid; grid-template-columns: 1fr; gap: var(--s-6); }
  @media (min-width: 800px) { .two-col { grid-template-columns: 1fr 1fr; } }
  .check-list { list-style: none; padding: 0; margin: 0; }
  .check-list li { padding: var(--s-2) 0 var(--s-2) 1.75rem; position: relative; border-bottom: 1px dashed var(--c-border); }
  .check-list li::before { content: '✓'; position: absolute; left: 0; top: 50%; transform: translateY(-50%); color: var(--c-accent); font-weight: 700; }
  .muted { color: var(--c-text-muted); font-size: 0.95rem; }
  .sectors__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--s-3); margin-top: var(--s-4); }
  .sectors__grid > div { background: var(--c-cream); padding: var(--s-3) var(--s-4); border-radius: var(--r-card); border-left: 3px solid var(--c-accent); }
  .sectors__grid strong { display: block; color: var(--c-primary); margin-bottom: 4px; }
  .sectors__grid span { color: var(--c-text-muted); font-size: 0.9rem; }
  .numbered-list { list-style: none; padding: 0; margin: var(--s-4) 0; display: flex; flex-direction: column; gap: var(--s-3); }
  .numbered-list li { display: flex; gap: var(--s-3); align-items: flex-start; }
  .numbered-list span { color: var(--c-accent-dark); font-weight: 800; font-size: 1.1rem; flex-shrink: 0; width: 1.5rem; }
  .numbered-list strong { color: var(--c-primary); }
  .faq details { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--r-card); margin-bottom: var(--s-2); }
  .faq summary { padding: var(--s-3) var(--s-4); cursor: pointer; font-weight: 600; color: var(--c-primary); list-style: none; position: relative; }
  .faq summary::after { content: '+'; position: absolute; right: var(--s-4); top: 50%; transform: translateY(-50%); color: var(--c-accent); font-size: 1.5rem; line-height: 1; transition: transform var(--t); }
  .faq details[open] summary::after { transform: translateY(-50%) rotate(45deg); }
  .faq details p { padding: 0 var(--s-4) var(--s-4); margin: 0; color: var(--c-text-muted); }
</style>
