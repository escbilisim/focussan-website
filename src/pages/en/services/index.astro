---
import Layout from '../../../layouts/Layout.astro';
import CTASection from '../../../components/CTASection.astro';
---

<Layout
  title="Services · Focussan"
  description="Two main service lines: industrial subcontract powder coating up to 8 metres, and VESA-standard TV mounting bracket manufacturing."
  locale="en"
>
  <section class="hero section">
    <div class="container container--narrow">
      <p class="hero__eyebrow">SERVICES</p>
      <h1>Two Main Lines of Business</h1>
      <p class="lead">
        Same facility, same quality standard, two complementary operations: industrial subcontract powder coating and our own TV mounting bracket production.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        <a href="/en/services/powder-coating" class="service-card">
          <p class="service-card__tag">SERVICE 1</p>
          <h2>Industrial Powder Coating</h2>
          <p>
            Subcontract electrostatic powder coating up to 8 metres. Full RAL palette, matte / gloss / semi-matte / textured finishes, 2-5 business day average turnaround. For automotive, profile, racking, electrical, architectural metalwork and agricultural equipment sectors.
          </p>
          <ul>
            <li>Up to 8 m part length</li>
            <li>Full RAL Classic + Design palette</li>
            <li>4 finish options</li>
            <li>Solvent-free · environmentally friendly</li>
          </ul>
          <span class="service-card__action">View details →</span>
        </a>

        <a href="/en/services/tv-mounts" class="service-card">
          <p class="service-card__tag">SERVICE 2</p>
          <h2>VESA TV Mount Manufacturing</h2>
          <p>
            Galvanised steel + matte black electrostatic powder coating, universal VESA compatibility. 4 product families: fixed body (35-100 cm), 6-arm articulating, butterfly, ceiling mount. Single units, wholesale and project pricing.
          </p>
          <ul>
            <li>4 families · 7 main models</li>
            <li>VESA 75×75 to 600×400 universal plate</li>
            <li>Cable management standard</li>
            <li>B2B project pricing</li>
          </ul>
          <span class="service-card__action">View details →</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection
    locale="en"
    title="Which service fits you?"
    description="Send us your inquiry — we'll point you to the right team."
  />
</Layout>

<style>
  .hero { padding-top: var(--s-7); padding-bottom: var(--s-5); }
  .hero__eyebrow { color: var(--c-accent-dark); font-weight: 700; font-size: 0.85rem; letter-spacing: 0.16em; margin: 0 0 var(--s-3); }
  .services-grid { display: grid; grid-template-columns: 1fr; gap: var(--s-4); }
  @media (min-width: 800px) { .services-grid { grid-template-columns: 1fr 1fr; } }
  .service-card { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--r-card); padding: var(--s-5); text-decoration: none; color: var(--c-text); display: flex; flex-direction: column; gap: var(--s-3); transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast); }
  .service-card:hover { border-color: var(--c-accent); box-shadow: var(--sh-mid); transform: translateY(-2px); }
  .service-card__tag { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.16em; color: var(--c-accent-dark); margin: 0; text-transform: uppercase; }
  .service-card h2 { font-size: 1.5rem; margin: 0; }
  .service-card p { color: var(--c-text-muted); margin: 0; }
  .service-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--s-2); }
  .service-card li { padding-left: 1.5rem; position: relative; color: var(--c-text); font-size: 0.95rem; }
  .service-card li::before { content: '▸'; position: absolute; left: 0; color: var(--c-accent); font-weight: 700; }
  .service-card__action { margin-top: auto; color: var(--c-accent-dark); font-weight: 600; padding-top: var(--s-3); border-top: 1px solid var(--c-border); }
</style>
