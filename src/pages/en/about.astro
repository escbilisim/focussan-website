---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Focussan Metal Sanayi Ticaret A.Ş.',
  alternateName: 'Focussan',
  url: 'https://focussan.com',
  logo: 'https://focussan.com/logo.png',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'DESB OSB Deliklikaya Mah. GünAlan Caddesi No: 23/1',
    addressLocality: 'Arnavutköy',
    addressRegion: 'İstanbul',
    addressCountry: 'TR',
  },
  telephone: '+90 212 873 07 34',
  email: 'muhasebe@focussan.com',
  knowsAbout: ['Electrostatic Powder Coating', 'Industrial Metal Coating', 'VESA TV Mounting Brackets', 'Galvanised Steel'],
};
---

<Layout
  title="About · Focussan Metal Manufacturing"
  description="Focussan is a domestic Turkish manufacturer based at DESB OSB Arnavutköy, Istanbul. Industrial powder coating, VESA-compliant TV mounting brackets, and contract assembly + packaging."
  locale="en"
>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <section class="hero section">
    <div class="container container--narrow">
      <p class="hero__eyebrow">ABOUT</p>
      <h1>Focussan Metal Manufacturing</h1>
      <p class="lead">
        Domestic manufacturer based at DESB Organised Industrial Zone in Arnavutköy, Istanbul. Industrial electrostatic powder coating, VESA-standard TV mounting bracket production, and contract assembly + packaging on a shared facility.
      </p>
    </div>
  </section>

  <section class="team-photo">
    <div class="container">
      <figure>
        <picture>
          <source
            type="image/webp"
            srcset="/images/team-800.webp 800w, /images/team-1600.webp 1600w"
            sizes="(min-width: 940px) 900px, 100vw"
          />
          <img
            src="/images/team-1600.jpg"
            srcset="/images/team-800.jpg 800w, /images/team-1600.jpg 1600w"
            sizes="(min-width: 940px) 900px, 100vw"
            width="1600"
            height="936"
            alt="The Focussan team in front of the DESB OSB facility, Arnavutköy"
            loading="eager"
            decoding="async"
          />
        </picture>
        <figcaption>The Focussan team · DESB OSB facility, Arnavutköy</figcaption>
      </figure>
    </div>
  </section>

  <section class="section about-intro">
    <div class="container container--narrow">
      <p>
        We run three main lines of business: <strong>powder coating</strong>, <strong>VESA TV mount manufacturing</strong>, and <strong>contract assembly</strong>. The first serves industrial customers with coating capacity for parts up to 8 metres. The second produces matte black VESA-compliant brackets on galvanised steel using our own coating line. The third combines parts we coat with components our customers supply, runs quality control, and packages the finished product ready to ship. Three operations, one facility, one quality standard.
      </p>
      <p>
        Our DESB OSB location offers two advantages: proximity to Istanbul Airport and the TEM motorway means <strong>fast dispatch</strong>, and being inside one of Turkey's largest organised industrial zones means a <strong>short supply chain</strong>.
      </p>
    </div>
  </section>

  <section class="section section--cream values">
    <div class="container">
      <h2>Operating Principles</h2>
      <div class="values__grid">
        <article>
          <h3>Quality</h3>
          <p>From surface preparation to film thickness measurement, every stage passes documented control points. A part with poor adhesion does not ship.</p>
        </article>
        <article>
          <h3>On-Time Delivery</h3>
          <p>Standard work averages 2-5 business days. We honour the date quoted; if anything shifts we tell you in advance.</p>
        </article>
        <article>
          <h3>Transparent Pricing</h3>
          <p>Powder coating is not a fixed price list. Quantity, surface area, coating type and colour changes are shown openly in the quote.</p>
        </article>
        <article>
          <h3>Sustainability</h3>
          <p>Powder coating is solvent-free with zero VOC emissions. Most unused powder is recovered, producing minimal waste.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section capacity">
    <div class="container">
      <div class="capacity__grid">
        <div>
          <h2>Capacity</h2>
          <p>The facility was set up for large-part powder coating. Most subcontract shops cap at 3-4 metres; we handle parts up to <strong>8 metres</strong>.</p>
        </div>
        <ul class="capacity__stats">
          <li><strong>8 m</strong><span>Max part length</span></li>
          <li><strong>RAL</strong><span>Full colour palettes</span></li>
          <li><strong>2-5 days</strong><span>Average turnaround</span></li>
          <li><strong>4 finishes</strong><span>Matte, gloss, semi-matte, textured</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--cream location">
    <div class="container container--narrow">
      <h2>Location</h2>
      <p><strong>DESB OSB</strong> · Deliklikaya Mah. GünAlan Caddesi No: 23/1, Arnavutköy / İstanbul</p>
      <ul class="check-list">
        <li>Near Istanbul Airport · export logistics</li>
        <li>Direct access to TEM and Northern Marmara motorways</li>
        <li>Daily dispatch network across Istanbul</li>
        <li>Road advantage toward Thrace and Europe</li>
      </ul>
    </div>
  </section>

  <CTASection
    locale="en"
    title="Ready to work together?"
    description="Reach out for a powder coating job or a TV mount project."
  />
</Layout>

<style>
  .hero { padding-top: var(--s-7); padding-bottom: var(--s-5); }
  .hero__eyebrow { color: var(--c-accent-dark); font-weight: 700; font-size: 0.85rem; letter-spacing: 0.16em; margin: 0 0 var(--s-3); }
  .section--cream { background: var(--c-white); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border); }
  .about-intro p { font-size: 1.05rem; }
  .team-photo { padding: 0 0 var(--s-5); }
  .team-photo figure { margin: 0 auto; max-width: 900px; }
  .team-photo picture, .team-photo img { display: block; width: 100%; height: auto; border-radius: var(--r-card); overflow: hidden; }
  .team-photo figcaption { margin-top: 0.3rem; font-size: 0.85rem; color: var(--c-text-muted); text-align: center; }
  .values__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--s-4); margin-top: var(--s-4); }
  .values__grid article { background: var(--c-cream); padding: var(--s-4); border-radius: var(--r-card); border-top: 3px solid var(--c-accent); }
  .values__grid h3 { font-size: 1.1rem; margin: 0 0 var(--s-2); }
  .values__grid p { color: var(--c-text-muted); font-size: 0.95rem; margin: 0; }
  .capacity__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-5); align-items: center; }
  @media (min-width: 800px) { .capacity__grid { grid-template-columns: 1.2fr 1fr; } }
  .capacity__stats { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); }
  .capacity__stats li { background: var(--c-white); padding: var(--s-3); border-radius: var(--r-card); text-align: center; border: 1px solid var(--c-border); }
  .capacity__stats strong { display: block; font-size: 1.4rem; color: var(--c-primary); font-weight: 800; }
  .capacity__stats span { font-size: 0.8rem; color: var(--c-text-muted); }
  .check-list { list-style: none; padding: 0; margin: var(--s-3) 0 0; }
  .check-list li { padding: var(--s-2) 0 var(--s-2) 1.75rem; position: relative; border-bottom: 1px dashed var(--c-border); }
  .check-list li::before { content: '✓'; position: absolute; left: 0; top: 50%; transform: translateY(-50%); color: var(--c-accent); font-weight: 700; }
</style>
