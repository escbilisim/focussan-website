---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';
import { CONTACT } from '../../data/site';

const services = [
  {
    href: '/en/services/powder-coating',
    tag: 'SERVICE 1',
    title: 'Electrostatic Powder Coating',
    body: 'Parts up to 8 m, full RAL palette, four finish options and 2-5 business day turnaround. Automotive, profile, racking, electrical enclosures and architectural metal.',
  },
  {
    href: '/en/services/tv-mounts',
    tag: 'SERVICE 2',
    title: 'VESA TV Mounting Brackets',
    body: 'Galvanised steel body, matte black powder coat, universal VESA compatibility. Four product families with cable management standard. Single-unit, wholesale and project quotes.',
  },
  {
    href: '/en/services/contract-assembly',
    tag: 'SERVICE 3',
    title: 'Contract Assembly Line',
    body: 'We combine the parts we coat with the components you supply, run quality control, and package the finished product. Single supplier, single logistics loop, single QC checkpoint.',
  },
];

const reasons = [
  {
    title: 'Parts up to 8 metres',
    body: 'Our oven line handles parts up to 8 metres long in a single pass. Most subcontract shops cap out at 3-4 metres.',
  },
  {
    title: '2-5 business day turnaround',
    body: 'Standard jobs ship in 2-5 business days. We confirm an exact timeline at quote stage based on volume, colour changes and surface prep.',
  },
  {
    title: 'Full RAL palette',
    body: 'All 213 RAL Classic colours, 1,625 RAL Design colours, plus matte, gloss, semi-matte and textured finishes as standard.',
  },
  {
    title: 'Integrated manufacturer',
    body: 'We coat our own VESA TV brackets in-house. Being both a subcontract shop and an end-product manufacturer means we know the process from the inside.',
  },
];

const miniFaqs = [
  {
    q: 'Which metals can you coat?',
    a: 'Steel, aluminium, stainless, galvanised and cast iron — any conductive surface. Plastic, wood and MDF are not suitable for powder coating.',
  },
  {
    q: 'How long a part can you coat?',
    a: 'Up to 8 metres in a single pass. For oversized industrial parts we are one of a limited number of shops in Türkiye that can handle the length.',
  },
  {
    q: 'How is pricing calculated?',
    a: 'Per part: quantity, surface area, coating type, number of colour changes and surface preparation complexity. Send a drawing or sample photo and we return a firm quote.',
  },
  {
    q: 'How do I find my TV\'s VESA pattern?',
    a: 'It is printed in the user manual or on the back panel label. Our brackets support VESA 75×75 to 600×400 on a single plate.',
  },
];
---

<Layout
  title="Focussan — Industrial Powder Coating & Metal Solutions"
  description="Istanbul-based domestic manufacturer offering subcontract electrostatic powder coating up to 8 metres and VESA-compliant TV mounting brackets. Located at DESB OSB Arnavutköy."
  locale="en"
>
  <section class="home-hero">
    <div class="home-hero__bg">
      <img
        src="/images/home-hero-1600.webp"
        srcset="/images/home-hero-960.webp 960w, /images/home-hero-1600.webp 1600w, /images/home-hero.webp 2752w"
        sizes="100vw"
        alt="Electrostatic powder coating in the Focussan spray booth"
        width="2752"
        height="1536"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="container home-hero__container">
      <div class="home-hero__card">
        <p class="home-hero__eyebrow">FOCUSSAN</p>
        <h1>Industrial Powder Coating &amp; Metal Solutions</h1>
        <p class="home-hero__lead">
          Domestic manufacturer based at DESB OSB, Arnavutköy, Istanbul. Subcontract electrostatic powder coating for parts up to 8 metres, plus VESA-compliant TV mounting brackets.
        </p>
        <div class="home-hero__cta">
          <a href={CONTACT.whatsappHref} class="btn btn--primary" target="_blank" rel="noopener">Get a Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-trust">
    <div class="container">
      <ul class="home-trust__grid">
        <li><strong>8 m</strong><span>Maximum part length</span></li>
        <li><strong>RAL</strong><span>Full palette access</span></li>
        <li><strong>2-5 days</strong><span>Average turnaround</span></li>
        <li><strong>VESA</strong><span>Compliant TV mounts</span></li>
        <li><strong>DESB OSB</strong><span>Istanbul Arnavutköy</span></li>
      </ul>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-blockhead">
        <p class="home-blockhead__eyebrow">OUR SERVICES</p>
        <h2>Three complementary lines of business</h2>
        <p class="home-blockhead__lead">Same facility, same quality standard, three lines running side by side: coating, our own product, contract assembly.</p>
      </div>

      <div class="home-services">
        {services.map((s) => (
          <a href={s.href} class="home-service-card">
            <p class="home-service-card__tag">{s.tag}</p>
            <h3>{s.title}</h3>
            <p class="home-service-card__body">{s.body}</p>
            <span class="home-service-card__action">See details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section home-section--alt">
    <div class="container">
      <div class="home-blockhead">
        <p class="home-blockhead__eyebrow">WHY FOCUSSAN</p>
        <h2>Capacity, speed and colour flexibility</h2>
      </div>

      <div class="home-reasons">
        {reasons.map((r, i) => (
          <article class="home-reason-card">
            <span class="home-reason-card__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{r.title}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section home-video">
    <div class="container container--narrow">
      <div class="home-blockhead home-blockhead--light">
        <p class="home-blockhead__eyebrow home-blockhead__eyebrow--accent">INSIDE THE FACTORY</p>
        <h2>See the production line</h2>
      </div>

      <div class="home-video__frame">
        <video
          id="factory-video"
          controls
          preload="none"
          poster="/videos/focussan-tanitim-poster.jpg"
          playsinline
        >
          <source src="/videos/focussan-tanitim.webm" type="video/webm" />
          <source src="/videos/focussan-tanitim.mp4" type="video/mp4" />
          Your browser does not support HTML5 video.
        </video>
        <button class="home-video__play" type="button" aria-label="Play walkthrough video">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container container--narrow">
      <div class="home-blockhead">
        <p class="home-blockhead__eyebrow">QUICK ANSWERS</p>
        <h2>Four most asked questions</h2>
      </div>

      <div class="home-faq">
        {miniFaqs.map((f) => (
          <details class="home-faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <p class="home-faq__more">
        For the full list, see our <a href="/en/faq">FAQ</a> page.
      </p>
    </div>
  </section>

  <CTASection
    locale="en"
    title="Get a quote for your project"
    description="Send a part drawing or sample photo and we'll come back with a firm timeline and price."
  />
</Layout>

<script>
  const video = document.getElementById('factory-video') as HTMLVideoElement | null;
  const btn = document.querySelector<HTMLButtonElement>('.home-video__play');
  if (video && btn) {
    const hide = () => btn.setAttribute('hidden', '');
    const show = () => btn.removeAttribute('hidden');
    btn.addEventListener('click', () => {
      video.play();
      hide();
    });
    video.addEventListener('play', hide);
    video.addEventListener('ended', show);
  }
</script>

<style>
  /* ===== Hero (background image + content card) ===== */
  .home-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: 580px;
    padding: var(--s-7) 0;
  }
  .home-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .home-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .home-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(6, 15, 24, 0.55) 0%, rgba(6, 15, 24, 0.25) 60%, rgba(6, 15, 24, 0.55) 100%);
  }
  .home-hero__container {
    position: relative;
    z-index: 1;
  }
  .home-hero__card {
    background: rgba(247, 244, 237, 0.72);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: var(--r-lg);
    padding: var(--s-6) var(--s-5);
    box-shadow: 0 12px 40px rgba(6, 15, 24, 0.25);
    text-align: center;
    max-width: 640px;
    margin: 0 0 0 auto;
  }
  .home-hero__card h1 {
    margin: 0 0 var(--s-3);
  }
  .home-hero__eyebrow {
    color: var(--c-accent-dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    margin: 0 0 var(--s-3);
  }
  .home-hero__lead {
    color: var(--c-text-muted);
    font-size: 1.125rem;
    margin: 0 0 var(--s-4);
  }
  .home-hero__cta {
    display: flex;
    gap: var(--s-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ===== Trust strip ===== */
  .home-trust {
    background: var(--c-white);
    border-bottom: 1px solid var(--c-border);
    padding: var(--s-5) 0;
  }
  .home-trust__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--s-4);
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
  }
  .home-trust__grid li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .home-trust__grid strong {
    font-size: 1.5rem;
    color: var(--c-primary);
    font-weight: 800;
  }
  .home-trust__grid span {
    font-size: 0.85rem;
    color: var(--c-text-muted);
  }

  /* ===== Generic section ===== */
  .home-section {
    padding: var(--s-7) 0;
  }
  .home-section--alt {
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }

  /* ===== Block head ===== */
  .home-blockhead {
    text-align: center;
    max-width: var(--max-w-narrow);
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--s-5);
  }
  .home-blockhead h2 {
    margin: 0 0 var(--s-3);
  }
  .home-blockhead__eyebrow {
    color: var(--c-accent-dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    margin: 0 0 var(--s-2);
  }
  .home-blockhead__eyebrow--accent {
    color: var(--c-accent-light);
  }
  .home-blockhead__lead {
    color: var(--c-text-muted);
    font-size: 1.05rem;
    margin: 0;
  }
  .home-blockhead--light .home-blockhead__lead {
    color: var(--c-text-light);
  }
  .home-blockhead--light h2 {
    color: var(--c-white);
  }

  /* ===== Services grid (3 cards responsive: 1 / 2 / 3 col) ===== */
  .home-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  @media (min-width: 700px) {
    .home-services {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .home-services {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .home-service-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    padding: var(--s-5);
    text-decoration: none;
    color: var(--c-text);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  }
  .home-service-card:hover {
    border-color: var(--c-accent);
    box-shadow: var(--sh-mid);
    transform: translateY(-2px);
    color: var(--c-text);
  }
  .home-service-card__tag {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--c-accent-dark);
    margin: 0;
    text-transform: uppercase;
  }
  .home-service-card h3 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--c-primary);
  }
  .home-service-card__body {
    color: var(--c-text-muted);
    margin: 0;
    flex: 1;
  }
  .home-service-card__action {
    margin-top: auto;
    color: var(--c-accent-dark);
    font-weight: 600;
    padding-top: var(--s-3);
    border-top: 1px solid var(--c-border);
  }

  /* ===== Reasons ===== */
  .home-reasons {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  @media (min-width: 700px) {
    .home-reasons {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .home-reasons {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .home-reason-card {
    background: var(--c-cream);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .home-reason-card__num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--c-accent-dark);
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .home-reason-card h3 {
    font-size: 1.1rem;
    margin: 0;
    color: var(--c-primary);
  }
  .home-reason-card p {
    color: var(--c-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  /* ===== Video teaser ===== */
  .home-video {
    background: var(--c-primary-deep);
    color: var(--c-text-light);
  }
  .home-video__frame {
    position: relative;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.08);
    aspect-ratio: 16 / 9;
    display: flex;
  }
  .home-video__frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-video__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: rgba(255, 106, 0, 0.92);
    border: 4px solid rgba(255, 255, 255, 0.92);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    padding: 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    transition: background var(--t-fast), transform var(--t-fast);
  }
  .home-video__play:hover,
  .home-video__play:focus-visible {
    background: var(--c-accent);
    transform: translate(-50%, -50%) scale(1.06);
  }
  .home-video__play svg {
    width: 38px;
    height: 38px;
    fill: #fff;
    margin-left: 4px;
  }
  .home-video__play[hidden] {
    display: none;
  }
  @media (max-width: 600px) {
    .home-video__play {
      width: 72px;
      height: 72px;
      border-width: 3px;
    }
    .home-video__play svg {
      width: 28px;
      height: 28px;
    }
  }
  .home-video__placeholder {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    align-items: center;
    justify-content: center;
    color: var(--c-text-light-muted);
    background: radial-gradient(circle at center, rgba(255, 106, 0, 0.12), transparent 60%), var(--c-primary-deep);
  }
  .home-video__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    color: var(--c-accent-light);
    padding-left: 6px;
  }
  .home-video__label {
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }

  /* ===== Mini FAQ ===== */
  .home-faq {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .home-faq__item {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
  }
  .home-faq__item summary {
    padding: var(--s-3) var(--s-4);
    cursor: pointer;
    font-weight: 600;
    color: var(--c-primary);
    list-style: none;
    position: relative;
  }
  .home-faq__item summary::-webkit-details-marker { display: none; }
  .home-faq__item summary::after {
    content: '+';
    position: absolute;
    right: var(--s-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--c-accent);
    font-size: 1.5rem;
    line-height: 1;
    transition: transform var(--t);
  }
  .home-faq__item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }
  .home-faq__item p {
    padding: 0 var(--s-4) var(--s-4);
    margin: 0;
    color: var(--c-text-muted);
    line-height: 1.7;
  }
  .home-faq__more {
    margin-top: var(--s-4);
    text-align: center;
    color: var(--c-text-muted);
    font-size: 0.95rem;
  }

  /* ===== Mobile tuning ===== */
  @media (max-width: 600px) {
    .home-hero {
      min-height: 480px;
      padding: var(--s-6) 0;
    }
    .home-hero__card {
      padding: var(--s-5) var(--s-4);
    }
  }
</style>
