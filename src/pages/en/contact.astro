---
import Layout from '../../layouts/Layout.astro';
import { CONTACT } from '../../data/site';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://focussan.com/#localbusiness',
  name: 'Focussan Metal Sanayi Ticaret A.Ş.',
  alternateName: 'Focussan',
  url: 'https://focussan.com',
  logo: 'https://focussan.com/logo.png',
  image: 'https://focussan.com/logo.png',
  telephone: '+90 212 873 07 34',
  email: 'muhasebe@focussan.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'DESB OSB Deliklikaya Mah. GünAlan Caddesi No: 23/1',
    addressLocality: 'Arnavutköy',
    addressRegion: 'İstanbul',
    addressCountry: 'TR',
  },
  areaServed: { '@type': 'Country', name: 'Turkey' },
};
---

<Layout
  title="Contact · Focussan"
  description="Get in touch with Focussan: phone +90 212 873 07 34, WhatsApp +90 538 684 7373, email muhasebe@focussan.com. DESB OSB Arnavutköy / Istanbul."
  locale="en"
  ogImage="/og/contact.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <section class="hero section">
    <div class="container container--narrow">
      <p class="hero__eyebrow">CONTACT</p>
      <h1>Get in Touch</h1>
      <p class="lead">
        Reach out about a powder coating job, a TV mount inquiry or a project quote through any of the channels below. We typically respond within the same business day.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <a href={CONTACT.whatsappHref} class="contact-card contact-card--accent" target="_blank" rel="noopener">
          <p class="contact-card__label">FASTEST</p>
          <h3>WhatsApp</h3>
          <p>{CONTACT.whatsapp}</p>
          <span class="contact-card__action">Send a message →</span>
        </a>

        <a href={CONTACT.phoneHref} class="contact-card">
          <p class="contact-card__label">PHONE</p>
          <h3>{CONTACT.phone}</h3>
          <p>Weekdays during business hours</p>
          <span class="contact-card__action">Call →</span>
        </a>

        <a href={`mailto:${CONTACT.email}`} class="contact-card">
          <p class="contact-card__label">EMAIL</p>
          <h3>{CONTACT.email}</h3>
          <p>For detailed inquiries, technical specs, invoicing</p>
          <span class="contact-card__action">Write →</span>
        </a>

        <div class="contact-card contact-card--info">
          <p class="contact-card__label">ADDRESS</p>
          <h3>DESB OSB · Arnavutköy</h3>
          <p>
            {CONTACT.address.line1}<br />
            {CONTACT.address.line2}<br />
            {CONTACT.address.district}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream form-placeholder">
    <div class="container container--narrow text-center">
      <h2>Online Quote Form</h2>
      <p class="lead">
        Our form infrastructure is in final preparation. For the fastest response please send part drawings or technical specs via <a href={CONTACT.whatsappHref} target="_blank" rel="noopener">WhatsApp</a>.
      </p>
    </div>
  </section>

  <section class="section section--dark hours">
    <div class="container container--narrow text-center">
      <h2>Business Hours</h2>
      <p>Monday-Saturday · during business hours</p>
      <p class="muted-light">For urgent shipments and project quotes WhatsApp accepts messages 24/7; we reply at the earliest opportunity.</p>
    </div>
  </section>
</Layout>

<style>
  .hero { padding-top: var(--s-7); padding-bottom: var(--s-5); }
  .hero__eyebrow { color: var(--c-accent-dark); font-weight: 700; font-size: 0.85rem; letter-spacing: 0.16em; margin: 0 0 var(--s-3); }
  .contact-grid { display: grid; grid-template-columns: 1fr; gap: var(--s-4); }
  @media (min-width: 700px) { .contact-grid { grid-template-columns: 1fr 1fr; } }
  .contact-card { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--r-card); padding: var(--s-4); text-decoration: none; color: var(--c-text); transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast); display: flex; flex-direction: column; gap: var(--s-2); }
  .contact-card:hover { border-color: var(--c-accent); box-shadow: var(--sh-mid); transform: translateY(-2px); }
  .contact-card--info { cursor: default; }
  .contact-card--info:hover { transform: none; border-color: var(--c-border); box-shadow: none; }
  .contact-card__label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; color: var(--c-accent-dark); margin: 0; text-transform: uppercase; }
  .contact-card h3 { margin: 0; font-size: 1.25rem; }
  .contact-card p { margin: 0; color: var(--c-text-muted); font-size: 0.95rem; }
  .contact-card__action { margin-top: auto; color: var(--c-accent-dark); font-weight: 600; font-size: 0.9rem; padding-top: var(--s-2); }
  /* Accent (dark) variant — must come AFTER base rules */
  .contact-card--accent { background: var(--c-primary); color: var(--c-white); border-color: var(--c-primary); }
  .contact-card--accent h3, .contact-card--accent p { color: var(--c-white); }
  .contact-card--accent .contact-card__label { color: var(--c-accent-light); }
  .contact-card--accent .contact-card__action { color: var(--c-accent-light); }
  .contact-card--accent:hover { background: var(--c-primary-mid); border-color: var(--c-accent); }
  .section--cream { background: var(--c-white); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border); }
  .muted-light { color: var(--c-text-light-muted) !important; font-size: 0.95rem; }
</style>
